<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Welcome to People Hub</title>
    <style>
      body { margin: 0; padding: 0; background: #f5f7fb; color: #0f172a;
      font-family: Arial, sans-serif; line-height: 1.6; } .container {
      max-width: 640px; margin: 24px auto; overflow: hidden; border: 1px solid
      #e2e8f0; border-radius: 12px; background: #ffffff; } .header { padding:
      24px 28px; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
      .brand { display: inline-flex; align-items: center; gap: 12px; } .mark {
      display: inline-block; width: 42px; height: 42px; border-radius: 10px;
      background: #0f172a; color: #ffffff; font-weight: 700; font-size: 14px;
      line-height: 42px; text-align: center; letter-spacing: 0.08em; } .brand
      strong { display: block; font-size: 16px; color: #0f172a; } .brand span {
      display: block; font-size: 12px; color: #64748b; } .content { padding:
      28px; } h1 { margin: 0 0 14px; font-size: 24px; line-height: 1.25; color:
      #0f172a; } p { margin: 0 0 16px; font-size: 15px; color: #334155; }
      .credential { margin: 18px 0; padding: 16px; border: 1px solid #e2e8f0;
      border-radius: 10px; background: #f8fafc; } .credential p { margin: 0
      0 10px; } .credential p:last-child { margin-bottom: 0; } .note { font-size:
      13px; color: #64748b; } .footer { padding: 18px 28px; border-top: 1px
      solid #e2e8f0; background: #ffffff; color: #64748b; font-size: 13px; }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <div class='brand'>
          <span class='mark'>PH</span>
          <span><strong>People Hub</strong><span>HR workspace access</span></span>
        </div>
      </div>

      <div class='content'>
        <h1>Welcome, {{name}}</h1>
        <p>Your People Hub account has been created. Use the credentials below
          to sign in for the first time.</p>

        <div class='credential'>
          <p><strong>Email:</strong> {{email}}</p>
          <p><strong>Temporary password:</strong> {{password}}</p>
        </div>

        <p class='note'>For security, change this password after your first
          login from your profile settings.</p>
      </div>

      <div class='footer'>
        Sent by People Hub. If you were not expecting this account, contact your
        HR team.
      </div>
    </div>
  </body>
</html>
