<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Password reset</title>
    <style>
      body { margin: 0; padding: 0; background: #f5f7fb; color: #0f172a;
      font-family: Arial, sans-serif; line-height: 1.6; } .container {
      max-width: 640px; margin: 24px auto; overflow: hidden; border: 1px solid
      #e2e8f0; border-radius: 12px; background: #ffffff; } .header { padding:
      24px 28px; border-bottom: 1px solid #e2e8f0; background: #f8fafc; }
      .mark { display: inline-block; width: 42px; height: 42px; border-radius:
      10px; background: #0f172a; color: #ffffff; font-weight: 700; font-size:
      14px; line-height: 42px; text-align: center; letter-spacing: 0.08em; }
      .brand { display: inline-flex; align-items: center; gap: 12px; } .brand
      strong { display: block; font-size: 16px; } .brand span span { display:
      block; font-size: 12px; color: #64748b; } .content { padding: 28px; } h1
      { margin: 0 0 14px; font-size: 24px; line-height: 1.25; } p { margin: 0
      0 16px; font-size: 15px; color: #334155; } .button { display:
      inline-block; margin-top: 8px; padding: 12px 18px; border-radius: 8px;
      background: #0f172a; color: #ffffff; font-size: 14px; font-weight: 700;
      text-decoration: none; } .note { margin-top: 20px; padding: 14px;
      border-radius: 10px; background: #f8fafc; color: #64748b; font-size:
      13px; } .footer { padding: 18px 28px; border-top: 1px solid #e2e8f0;
      color: #64748b; font-size: 13px; }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <div class='brand'>
          <span class='mark'>PH</span>
          <span><strong>People Hub</strong><span>Password recovery</span></span>
        </div>
      </div>

      <div class='content'>
        <h1>Reset your password</h1>
        <p>We received a request to reset your People Hub password. Use the
          button below to choose a new password.</p>

        <a class='button' href='{{resetUrl}}'>Reset password</a>

        <div class='note'>If you did not request this change, you can ignore
          this email. Your current password will stay unchanged.</div>
      </div>

      <div class='footer'>
        Sent by People Hub for account security.
      </div>
    </div>
  </body>
</html>
